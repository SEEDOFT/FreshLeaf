{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "FreshLeafApi/artisan",
                "boost:mcp"
            ]
        },
        "dart": {
            "type": "local",
            "enabled": true,
            "command": [
                "fresh_leaf/.fvm/flutter_sdk/bin/cache/dart-sdk/bin/dart",
                "mcp-server"
            ],
            "environment": {
                "DART_SDK": "D:\\FreshLeaf\\fresh_leaf\\.fvm\\flutter_sdk\\bin\\cache\\dart-sdk",
                "FLUTTER_SDK": "D:\\FreshLeaf\\fresh_leaf\\.fvm\\flutter_sdk"
            }
        }
    }
}
