{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "FreshLeafApi/artisan",
                "boost:mcp"
            ]
        },
        "dart": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "scripts/mcp/dart-mcp.php"
            ]
        }
    }
}
